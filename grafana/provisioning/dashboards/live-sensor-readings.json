          "query": "from(bucket: \"iot\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"sensor_readings\")\n  |> filter(fn: (r) => r.metric == \"pressure\")\n  |> filter(fn: (r) => r._field == \"value\")\n  |> last()"
