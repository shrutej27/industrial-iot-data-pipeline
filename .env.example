# =============================================================================
# Industrial IoT Data Pipeline — Environment Variables
# 1. Copy this file:  cp .env.example .env
# 2. Replace every CHANGE_ME value below with a strong, unique password/token
# 3. Run:  docker compose up -d --build
#
# SECURITY: The pipeline will NOT start if any required secret is missing.
#           Generate random values with:  openssl rand -hex 16
# =============================================================================

# ── Mosquitto ────────────────────────────────────────────────────────────────
MOSQUITTO_PORT=1883
MOSQUITTO_WS_PORT=9001

# ── InfluxDB ─────────────────────────────────────────────────────────────────
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_INIT_MODE=setup
INFLUXDB_INIT_USERNAME=admin
INFLUXDB_INIT_PASSWORD=CHANGE_ME_influxdb_password
INFLUXDB_INIT_ORG=factory
INFLUXDB_INIT_BUCKET=iot
INFLUXDB_INIT_ADMIN_TOKEN=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=iot
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
POSTGRES_DB=iot_pipeline

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_PORT=3000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_grafana_password

# ── MinIO (S3-compatible object storage) ─────────────────────────────────────
MINIO_ROOT_USER=CHANGE_ME_minio_user
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9002
MINIO_BUCKET=raw-data

# ── Node-RED ─────────────────────────────────────────────────────────────────
NODERED_PORT=1880

# ── OPC-UA Server ────────────────────────────────────────────────────────────
OPCUA_PORT=4840

# ── FastAPI ──────────────────────────────────────────────────────────────────
API_PORT=8000

# ── Anomaly Detector ─────────────────────────────────────────────────────────
ANOMALY_INTERVAL_SECONDS=60
ANOMALY_Z_THRESHOLD=3.0
ANOMALY_WINDOW_MINUTES=10
